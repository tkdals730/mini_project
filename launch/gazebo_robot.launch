<launch>

  <arg name="model" default="waffle_pi" />

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find night_patrol_robot)/worlds/office_patrolv2.world"/>
    <!-- <arg name="world_name" value="$(find night_patrol_robot)/worlds/office_patrol_nov2.world"/> -->
  </include>

  <param name="robot_description"
         command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro" />

  <node name="spawn_urdf" pkg="gazebo_ros" type="spawn_model"
        args="-urdf -model turtlebot3_$(arg model) -x 0 -y 0 -z 0.01 -param robot_description"
        output="screen" />

</launch>