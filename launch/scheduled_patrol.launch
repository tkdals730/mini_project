<launch>
  <!--
    예약 실행 전용 진입점입니다.
    실제 순찰 설정의 기본값은 patrol_one_button.launch에서 관리합니다.
  -->
  <arg name="start_time" default="22:00" />
  <arg name="end_time" default="06:00" />
  <arg name="check_period_sec" default="5.0" />
  <arg name="pause_before_shutdown_sec" default="1.0" />
  <arg name="graceful_stop_timeout_sec" default="600.0" />
  <arg name="publish_pause_on_idle" default="true" />
  <arg name="max_run_minutes" default="0.0" />
  <arg name="rest_minutes_after_run" default="0.0" />
  <arg name="preload_gazebo" default="true" />
  <arg name="reset_gazebo_pose_on_start" default="true" />
  <arg name="gazebo_model_name" default="turtlebot3_waffle_pi" />
  <arg name="patrol_launch_args" default="" />

  <node pkg="night_patrol_robot"
        type="scheduled_patrol_node.py"
        name="scheduled_patrol_node"
        output="screen"
        required="true">
    <param name="start_time" value="$(arg start_time)" />
    <param name="end_time" value="$(arg end_time)" />
    <param name="check_period_sec" value="$(arg check_period_sec)" />
    <param name="pause_before_shutdown_sec" value="$(arg pause_before_shutdown_sec)" />
    <param name="graceful_stop_timeout_sec" value="$(arg graceful_stop_timeout_sec)" />
    <param name="publish_pause_on_idle" value="$(arg publish_pause_on_idle)" />
    <param name="max_run_minutes" value="$(arg max_run_minutes)" />
    <param name="rest_minutes_after_run" value="$(arg rest_minutes_after_run)" />
    <param name="preload_gazebo" value="$(arg preload_gazebo)" />
    <param name="reset_gazebo_pose_on_start" value="$(arg reset_gazebo_pose_on_start)" />
    <param name="gazebo_model_name" value="$(arg gazebo_model_name)" />
    <param name="patrol_launch_args" value="$(arg patrol_launch_args)" />
  </node>
</launch>
