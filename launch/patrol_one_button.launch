<launch>
  <!--
    One-button entry point.
    mapping:=auto  -> map file이 없으면 맵핑, 있으면 저장 맵 순찰
    mapping:=true  -> 강제로 맵핑
    mapping:=false -> 강제로 저장 맵 순찰
  -->
  <arg name="mapping" default="auto" />
  <arg name="map_output" default="$(find night_patrol_robot)/maps/patrol_map" />
  <arg name="map_file" default="$(find night_patrol_robot)/maps/patrol_map.yaml" />
  <arg name="generated_waypoints_file" default="$(find night_patrol_robot)/maps/generated_patrol_waypoints.yaml" />
  <arg name="auto_generate_waypoints" default="true" />
  <arg name="generated_waypoint_count" default="6" />
  <arg name="generated_waypoint_spacing" default="1.8" />
  <arg name="generated_waypoint_min_spacing" default="1.6" />
  <arg name="generated_waypoint_clearance" default="0.35" />
  <arg name="patrol_loop" default="false" />
  <arg name="return_home" default="true" />
  <arg name="patrol_wait_sec" default="5.0" />
  <arg name="use_rviz" default="true" />
  <arg name="use_camera_viewer" default="true" />
  <arg name="use_fire_detection" default="true" />
  <arg name="camera_view_topic" default="/fire_detection/debug_image" />
  <arg name="mapping_strategy" default="frontier" />
  <!-- rviz 설정 -->
  <arg name="rviz_config" default="$(find night_patrol_robot)/rviz/patrol.rviz" />
  <!-- 맵 설정 -->
  <arg name="world_name" default="$(find night_patrol_robot)/worlds/office_patrol_nov4.world" />
  <arg name="frontier_goal_timeout_sec" default="25.0" />
  <arg name="frontier_min_goal_distance" default="0.4" />
  <arg name="frontier_max_goal_distance" default="0.0" />
  <arg name="frontier_blacklist_radius" default="0.2" />
  <arg name="frontier_area_blacklist_radius" default="0.6" />
  <arg name="frontier_blacklist_ttl_sec" default="90.0" />
  <arg name="frontier_blacklist_max_size" default="30" />
  <arg name="frontier_clearance_cells" default="2" />
  <arg name="frontier_viewpoint_clearance_cells" default="3" />
  <arg name="frontier_viewpoint_require_known_space" default="false" />
  <arg name="frontier_occupied_threshold" default="40" />
  <arg name="frontier_information_radius_cells" default="4" />
  <arg name="frontier_obstacle_penalty_radius_cells" default="3" />
  <arg name="frontier_information_gain_weight" default="3.0" />
  <arg name="frontier_distance_weight" default="1.0" />
  <arg name="frontier_obstacle_penalty_weight" default="1.0" />
  <arg name="frontier_min_cluster_size" default="5" />
  <arg name="frontier_size_weight" default="0.5" />
  <arg name="frontier_max_score_distance" default="4.0" />
  <arg name="frontier_prefer_nearest" default="false" />
  <arg name="frontier_nearest_score_tolerance" default="1.5" />
  <arg name="frontier_local_radius" default="1.2" />
  <arg name="frontier_local_bonus" default="2.0" />
  <arg name="exploration_complete_wait_sec" default="45.0" />
  <arg name="frontier_viewpoint_min_distance_cells" default="3" />
  <arg name="frontier_viewpoint_max_distance_cells" default="10" />
  <arg name="frontier_max_goal_failures_before_blacklist" default="2" />
  <arg name="frontier_suppress_reached_frontier" default="false" />
  <arg name="frontier_completion_spin_attempts" default="2" />
  <arg name="frontier_completion_spin_angular_speed" default="0.45" />
  <arg name="frontier_minimum_mapping_time_sec" default="120.0" />
  <arg name="frontier_progress_timeout_sec" default="60.0" />
  <arg name="frontier_free_cell_growth_threshold" default="25" />
  <arg name="frontier_min_suppressed_for_completion" default="3" />
  <arg name="frontier_force_completion_after_repeated_failures" default="true" />
  <arg name="spawn_x" default="0.0" />
  <arg name="spawn_y" default="0.55" />
  <arg name="spawn_z" default="0.01" />
  <arg name="spawn_yaw" default="1.5708" />
  <arg name="initial_pose_x" default="0.0" />
  <arg name="initial_pose_y" default="0.55" />
  <arg name="initial_pose_yaw" default="1.5708" />

  <node pkg="night_patrol_robot"
        type="patrol_launch_supervisor.py"
        name="patrol_launch_supervisor"
        output="screen"
        required="true">
    <param name="mapping" value="$(arg mapping)" />
    <param name="map_output" value="$(arg map_output)" />
    <param name="map_file" value="$(arg map_file)" />
    <param name="generated_waypoints_file" value="$(arg generated_waypoints_file)" />
    <param name="auto_generate_waypoints" value="$(arg auto_generate_waypoints)" />
    <param name="generated_waypoint_count" value="$(arg generated_waypoint_count)" />
    <param name="generated_waypoint_spacing" value="$(arg generated_waypoint_spacing)" />
    <param name="generated_waypoint_min_spacing" value="$(arg generated_waypoint_min_spacing)" />
    <param name="generated_waypoint_clearance" value="$(arg generated_waypoint_clearance)" />
    <param name="patrol_loop" value="$(arg patrol_loop)" />
    <param name="return_home" value="$(arg return_home)" />
    <param name="patrol_wait_sec" value="$(arg patrol_wait_sec)" />
    <param name="use_rviz" value="$(arg use_rviz)" />
    <param name="use_camera_viewer" value="$(arg use_camera_viewer)" />
    <param name="use_fire_detection" value="$(arg use_fire_detection)" />
    <param name="camera_view_topic" value="$(arg camera_view_topic)" />
    <param name="mapping_strategy" value="$(arg mapping_strategy)" />
    <param name="rviz_config" value="$(arg rviz_config)" />
    <param name="world_name" value="$(arg world_name)" />
    <param name="frontier_goal_timeout_sec" value="$(arg frontier_goal_timeout_sec)" />
    <param name="frontier_min_goal_distance" value="$(arg frontier_min_goal_distance)" />
    <param name="frontier_max_goal_distance" value="$(arg frontier_max_goal_distance)" />
    <param name="frontier_blacklist_radius" value="$(arg frontier_blacklist_radius)" />
    <param name="frontier_area_blacklist_radius" value="$(arg frontier_area_blacklist_radius)" />
    <param name="frontier_blacklist_ttl_sec" value="$(arg frontier_blacklist_ttl_sec)" />
    <param name="frontier_blacklist_max_size" value="$(arg frontier_blacklist_max_size)" />
    <param name="frontier_clearance_cells" value="$(arg frontier_clearance_cells)" />
    <param name="frontier_viewpoint_clearance_cells" value="$(arg frontier_viewpoint_clearance_cells)" />
    <param name="frontier_viewpoint_require_known_space" value="$(arg frontier_viewpoint_require_known_space)" />
    <param name="frontier_occupied_threshold" value="$(arg frontier_occupied_threshold)" />
    <param name="frontier_information_radius_cells" value="$(arg frontier_information_radius_cells)" />
    <param name="frontier_obstacle_penalty_radius_cells" value="$(arg frontier_obstacle_penalty_radius_cells)" />
    <param name="frontier_information_gain_weight" value="$(arg frontier_information_gain_weight)" />
    <param name="frontier_distance_weight" value="$(arg frontier_distance_weight)" />
    <param name="frontier_obstacle_penalty_weight" value="$(arg frontier_obstacle_penalty_weight)" />
    <param name="frontier_min_cluster_size" value="$(arg frontier_min_cluster_size)" />
    <param name="frontier_size_weight" value="$(arg frontier_size_weight)" />
    <param name="frontier_max_score_distance" value="$(arg frontier_max_score_distance)" />
    <param name="frontier_prefer_nearest" value="$(arg frontier_prefer_nearest)" />
    <param name="frontier_nearest_score_tolerance" value="$(arg frontier_nearest_score_tolerance)" />
    <param name="frontier_local_radius" value="$(arg frontier_local_radius)" />
    <param name="frontier_local_bonus" value="$(arg frontier_local_bonus)" />
    <param name="exploration_complete_wait_sec" value="$(arg exploration_complete_wait_sec)" />
    <param name="frontier_viewpoint_min_distance_cells" value="$(arg frontier_viewpoint_min_distance_cells)" />
    <param name="frontier_viewpoint_max_distance_cells" value="$(arg frontier_viewpoint_max_distance_cells)" />
    <param name="frontier_max_goal_failures_before_blacklist" value="$(arg frontier_max_goal_failures_before_blacklist)" />
    <param name="frontier_suppress_reached_frontier" value="$(arg frontier_suppress_reached_frontier)" />
    <param name="frontier_completion_spin_attempts" value="$(arg frontier_completion_spin_attempts)" />
    <param name="frontier_completion_spin_angular_speed" value="$(arg frontier_completion_spin_angular_speed)" />
    <param name="frontier_minimum_mapping_time_sec" value="$(arg frontier_minimum_mapping_time_sec)" />
    <param name="frontier_progress_timeout_sec" value="$(arg frontier_progress_timeout_sec)" />
    <param name="frontier_free_cell_growth_threshold" value="$(arg frontier_free_cell_growth_threshold)" />
    <param name="frontier_min_suppressed_for_completion" value="$(arg frontier_min_suppressed_for_completion)" />
    <param name="frontier_force_completion_after_repeated_failures" value="$(arg frontier_force_completion_after_repeated_failures)" />
    <param name="spawn_x" value="$(arg spawn_x)" />
    <param name="spawn_y" value="$(arg spawn_y)" />
    <param name="spawn_z" value="$(arg spawn_z)" />
    <param name="spawn_yaw" value="$(arg spawn_yaw)" />
    <param name="initial_pose_x" value="$(arg initial_pose_x)" />
    <param name="initial_pose_y" value="$(arg initial_pose_y)" />
    <param name="initial_pose_yaw" value="$(arg initial_pose_yaw)" />
  </node>
</launch>
