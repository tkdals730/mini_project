<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="office_fire_detection_test_world">
    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <include>
      <uri>model://sun</uri>
    </include>
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <scene>
      <ambient>0.15 0.15 0.18 1</ambient>
      <background>0.02 0.02 0.03 1</background>
    </scene>

    <!-- Simple walls so the camera sees a stable indoor-like background. -->
    <model name="back_wall">
      <static>true</static>
      <pose>2.8 0.0 1.0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <box>
              <size>0.15 4.0 2.0</size>
            </box>
          </geometry>
        </collision>
        <visual name="vis">
          <geometry>
            <box>
              <size>0.15 4.0 2.0</size>
            </box>
          </geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.35 0.35 0.35 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="left_wall">
      <static>true</static>
      <pose>1.4 2.0 1.0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <box>
              <size>2.8 0.15 2.0</size>
            </box>
          </geometry>
        </collision>
        <visual name="vis">
          <geometry>
            <box>
              <size>2.8 0.15 2.0</size>
            </box>
          </geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.35 0.35 0.35 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="right_wall">
      <static>true</static>
      <pose>1.4 -2.0 1.0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <box>
              <size>2.8 0.15 2.0</size>
            </box>
          </geometry>
        </collision>
        <visual name="vis">
          <geometry>
            <box>
              <size>2.8 0.15 2.0</size>
            </box>
          </geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.35 0.35 0.35 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Fire target placed directly in front of the default spawn pose. -->
    <model name="fire_target">
      <static>true</static>
      <pose>1.2 0.0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <box>
              <size>0.25 0.25 0.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="vis">
          <geometry>
            <box>
              <size>0.25 0.25 0.5</size>
            </box>
          </geometry>
          <material>
            <ambient>1.0 0.20 0.02 1</ambient>
            <diffuse>1.0 0.25 0.02 1</diffuse>
            <emissive>1.0 0.15 0.0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <light name="fire_light" type="point">
      <pose>1.2 0.0 1.0 0 0 0</pose>
      <diffuse>1 0.25 0.02 1</diffuse>
      <specular>1 0.2 0.02 1</specular>
      <attenuation>
        <range>1.5</range>
        <constant>0.5</constant>
        <linear>0.1</linear>
        <quadratic>0.01</quadratic>
      </attenuation>
      <cast_shadows>true</cast_shadows>
    </light>
  </world>
</sdf>
